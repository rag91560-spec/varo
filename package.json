{
  "name": "game-translator",
  "version": "1.0.0",
  "private": true,
  "main": "electron/main.js",
  "scripts": {
    "dev": "next dev --port 3100",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "electron:dev": "electron .",
    "electron:build": "next build && node scripts/prepare-build.js && electron-builder",
    "electron:pack": "next build && node scripts/prepare-build.js && electron-builder --dir"
  },
  "dependencies": {
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "electron-updater": "^6.3.0",
    "lucide-react": "^0.575.0",
    "next": "^16.1.6",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "tailwind-merge": "^3.5.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "electron": "^35.7.5",
    "electron-builder": "^26.8.1",
    "eslint": "^9",
    "eslint-config-next": "^16.1.6",
    "tailwindcss": "^4",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5"
  },
  "build": {
    "appId": "com.gametranslator.app",
    "productName": "게임번역기",
    "asar": true,
    "directories": {
      "output": "dist-electron"
    },
    "files": [
      "electron/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "build-staging/frontend",
        "to": "frontend"
      },
      {
        "from": "backend",
        "to": "backend",
        "filter": ["**/*.py", "*.txt"]
      },
      {
        "from": "data",
        "to": "data",
        "filter": ["**/*"]
      }
    ],
    "win": {
      "target": "nsis",
      "icon": "electron/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "electron/icon.ico"
    },
    "publish": {
      "provider": "generic",
      "url": "https://api.closedclaws.com/api/update"
    }
  }
}
